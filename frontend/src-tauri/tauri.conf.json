{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mi-saina",
  "version": "1.0.4",
  "identifier": "fr.misaina.app",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3001",
    "beforeDevCommand": "",
    "beforeBuildCommand": "MS_DESKTOP=1 npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "mi-saina",
        "width": 1200,
        "height": 820,
        "minWidth": 880,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
