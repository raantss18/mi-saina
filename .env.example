# mi-saina — Configuration
# Copier ce fichier en .env et adapter les valeurs

OLLAMA_BASE_URL=http://localhost:11434

# Modèle principal (raisonnement, génération de code, analyse)
# Exemples: qwen3.5:9b, magistral:small, deepseek-r1:8b, gemma3:12b
REASONING_MODEL=qwen3.5:9b

# Modèle rapide (nommage sessions, tâches courtes)
# Peut être identique au modèle principal
FAST_MODEL=qwen3.5:9b

# Modèle DÉDIÉ aux embeddings (mémoire sémantique). Garde un petit modèle :
# beaucoup de modèles génératifs (gemma3…) ne savent pas faire d'embeddings.
# À installer une fois : ollama pull nomic-embed-text
EMBED_MODEL=nomic-embed-text

HOST=0.0.0.0
PORT=8000
MAX_SEARCH_RESULTS=5
SHELL_TIMEOUT=30

# Demander une confirmation (Exécuter/Refuser) avant chaque commande shell
CONFIRM_MODE=risky
# Nombre max d'étapes agentiques (modèle → commande → résultat → modèle) par requête
MAX_AGENT_STEPS=6
